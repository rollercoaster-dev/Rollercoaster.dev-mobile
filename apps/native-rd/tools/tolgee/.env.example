# Copy to .env (gitignored) and fill in real values before `docker compose up`.
# Setup walkthrough: apps/native-rd/docs/tolgee.md

# Postgres credentials. Generated locally; never leaves the Mac mini.
POSTGRES_DB=tolgee
POSTGRES_USER=tolgee
POSTGRES_PASSWORD=change-me-strong-random-string

# Host path for the Postgres data volume. Documented as the canonical location
# so manual `pg_dump` backups have an obvious target. Use an absolute path —
# `~` is expanded by the shell before Docker sees it, so `~/tolgee-data/...`
# resolves correctly when you run `docker compose up` from this directory.
POSTGRES_DATA_DIR=~/tolgee-data/postgres

# Seeded admin account. Tolgee creates this on first boot; sign in once and
# change the password in the UI, then leave INITIAL_PASSWORD here as the
# original (Tolgee ignores the env var after the user exists).
TOLGEE_ADMIN_USERNAME=admin
TOLGEE_ADMIN_PASSWORD=change-me-strong-random-string
