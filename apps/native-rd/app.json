{
  "expo": {
    "name": "Rollercoaster.dev",
    "slug": "rollercoasterdev",
    "version": "0.1.18",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.rollercoaster.app",
      "icon": {
        "light": "./assets/icon.png",
        "dark": "./assets/icon-dark.png"
      },
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to record voice memos as evidence for your goals.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffe50c"
      },
      "package": "dev.rollercoaster.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#fafafa"
        }
      ],
      "react-native-edge-to-edge",
      "expo-sqlite",
      "expo-secure-store",
      "expo-video",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to record voice memos as evidence for your goals."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos for evidence capture.",
          "cameraPermission": "Allow $(PRODUCT_NAME) to use the camera to take photos as evidence."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to record video as evidence for your goals.",
          "microphonePermission": "Allow $(PRODUCT_NAME) to record audio when capturing video evidence.",
          "recordAudioAndroid": true
        }
      ],
      "expo-asset",
      "@react-native-community/datetimepicker",
      "./plugins/withResourceBundleDeploymentTarget",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4",
            "buildReactNativeFromSource": true
          }
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "rollercoasterdev",
          "project": "native-rd",
          "url": "https://sentry.io/"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Anybody.ttf",
            "./assets/fonts/Anybody_bold.ttf",
            "./assets/fonts/Instrument Sans.ttf",
            "./assets/fonts/Instrument Sans_bold.ttf",
            "./assets/fonts/DM Mono.ttf",
            "./assets/fonts/OpenDyslexic.otf",
            "./assets/fonts/OpenDyslexic_bold.otf",
            "./assets/fonts/Atkinson Hyperlegible.ttf",
            "./assets/fonts/Atkinson Hyperlegible_bold.ttf",
            "./assets/fonts/Lexend.ttf",
            "./assets/fonts/Lexend_bold.ttf"
          ]
        }
      ],
      [
        "expo-localization",
        {
          "supportedLocales": [
            "en",
            "de"
          ]
        }
      ]
    ],
    "locales": {
      "en": "./locales/en.json",
      "de": "./locales/de.json"
    },
    "extra": {
      "eas": {
        "projectId": "d7a5b9b4-48b0-460b-ab51-912e11cebd10"
      }
    },
    "owner": "rollercoasterdev"
  }
}
