{
  "name": "native-rd",
  "version": "0.1.7",
  "private": true,
  "license": "AGPL-3.0-only",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "ios": "bash scripts/run-ios.sh",
    "ios:device": "IOS_DEVICE_ID=\"${IOS_DEVICE_ID:?Set IOS_DEVICE_ID}\" bash scripts/run-ios.sh",
    "ios:e2e": "EXPO_PUBLIC_E2E_MODE=true bash scripts/run-ios.sh",
    "android": "bash scripts/run-android.sh",
    "android:device": "ANDROID_DEVICE_ID=\"${ANDROID_DEVICE_ID:?Set ANDROID_DEVICE_ID}\" bash scripts/run-android.sh",
    "web": "expo start --web",
    "type-check": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json && tsc --noEmit -p tsconfig.scripts.json && tsc --noEmit -p tsconfig.scripts-test.json",
    "build": "echo 'Expo app — no build step'",
    "eas-build-post-install": "cd ../.. && bun x turbo build --filter=native-rd^...",
    "lint": "expo lint",
    "test": "bash scripts/jest-node.sh",
    "test:db": "bash scripts/jest-node.sh src/db/__tests__/",
    "test:ci": "bash scripts/jest-node.sh --ci",
    "test:ci:smoke": "bash scripts/jest-node.sh --listTests",
    "test:watch": "bash scripts/jest-node.sh --watch",
    "storybook:native": "sb-rn-get-stories -c .storybook && EXPO_PUBLIC_STORYBOOK_ENABLED=true bash scripts/run-ios.sh",
    "storybook:web": "storybook dev -p 6006 --config-dir .storybook-web",
    "storybook:web:build": "storybook build --config-dir .storybook-web --output-dir .storybook-web-static",
    "test:e2e": "bash scripts/run-e2e.sh",
    "test:e2e:single": "maestro test",
    "logs:agent": "bash scripts/agent-logs.sh",
    "start:worktree": "bash scripts/worktree-boot.sh",
    "test:a11y": "bash scripts/a11y-audit.sh",
    "test:a11y:json": "bash scripts/a11y-audit.sh --json",
    "testflight:ios": "bash scripts/testflight-ios.sh",
    "gen:pseudo": "bun run scripts/generate-pseudo-locale.ts",
    "verify:badge": "bun run scripts/verify-badge.ts",
    "release-notes:lint": "bun run scripts/release-notes-lint.ts",
    "release-notes:generate": "bun run scripts/release-notes-generate.ts",
    "release-notes:split": "bun run scripts/release-notes-split.ts",
    "i18n:lint-source": "bun run scripts/i18n/lintSource.cli.ts",
    "i18n:bakeoff": "bash scripts/i18n/run-bakeoff.sh",
    "i18n:sync": "bun run scripts/i18n/sync.cli.ts"
  },
  "dependencies": {
    "@evolu/common": "^7.4.1",
    "@evolu/react": "^10.4.0",
    "@evolu/react-native": "^14.3.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-community/slider": "5.2.0",
    "@react-navigation/bottom-tabs": "^7.16.1",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.15.1",
    "@rollercoaster-dev/design-tokens": "workspace:*",
    "@rollercoaster-dev/openbadges-core": "workspace:*",
    "@sentry/cli": "3.4.3",
    "@sentry/react-native": "~8.12.0",
    "@storybook/addon-ondevice-actions": "^10.4.4",
    "@storybook/addon-ondevice-controls": "^10.4.4",
    "@storybook/react-native": "^10.4.4",
    "buffer": "^6.0.3",
    "expo": "~55.0.25",
    "expo-application": "~55.0.15",
    "expo-asset": "~55.0.17",
    "expo-audio": "~55.0.14",
    "expo-build-properties": "~55.0.14",
    "expo-camera": "~55.0.19",
    "expo-dev-client": "~55.0.35",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.19",
    "expo-font": "~55.0.7",
    "expo-haptics": "~55.0.14",
    "expo-image-picker": "~55.0.20",
    "expo-localization": "~55.0.15",
    "expo-secure-store": "~55.0.14",
    "expo-sharing": "~55.0.19",
    "expo-sqlite": "~55.0.16",
    "expo-status-bar": "~55.0.6",
    "expo-video": "~55.0.17",
    "i18next": "26.2.0",
    "openbadges-types": "^4.0.0",
    "phosphor-react-native": "^3.0.3",
    "png-chunks-encode": "^1.0.0",
    "png-chunks-extract": "^1.0.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "17.0.8",
    "react-native": "0.83.6",
    "react-native-edge-to-edge": "^1.7.0",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-keyboard-controller": "1.21.8",
    "react-native-nitro-modules": "^0.35.7",
    "react-native-quick-crypto": "1.1.5",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "~4.25.1",
    "react-native-svg": "15.15.5",
    "react-native-unistyles": "^3.0.0",
    "react-native-view-shot": "^5.1.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.4",
    "set.prototype.difference": "^1.1.7",
    "set.prototype.intersection": "^1.1.8",
    "set.prototype.isdisjointfrom": "^1.1.5",
    "set.prototype.issubsetof": "^1.1.4",
    "set.prototype.issupersetof": "^1.1.3",
    "set.prototype.symmetricdifference": "^1.1.3",
    "set.prototype.union": "^1.1.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.65",
    "@babel/core": "^7.26.0",
    "@babel/plugin-transform-dynamic-import": "^7.27.1",
    "@babel/plugin-transform-explicit-resource-management": "^7.28.6",
    "@babel/plugin-transform-modules-commonjs": "^7.28.6",
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/runtime": "7.29.2",
    "@storybook/react": "^10.4.0",
    "@storybook/react-native-web-vite": "^10.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "4.0.9",
    "@types/react": "~19.2.10",
    "ai": "^6.0.191",
    "babel-jest": "^30.2.0",
    "babel-preset-expo": "~55.0.22",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~55.0.1",
    "jest": "^30.2.0",
    "jest-expo": "~56.0.4",
    "js-yaml": "4.1.1",
    "promptfoo": "^0.121.12",
    "react-test-renderer": "19.2.0",
    "storybook": "10.4.0",
    "typescript": "~6.0.3"
  },
  "expo": {
    "install": {
      "exclude": [
        "@types/jest",
        "jest",
        "typescript"
      ]
    }
  }
}
